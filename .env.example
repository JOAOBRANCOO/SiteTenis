# ─── Servidor ────────────────────────────────────────────────────────────────
# Porta em que o servidor Express vai escutar
PORT=3000

# Ambiente de execução: development | production | test
NODE_ENV=development

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Para desenvolvimento local usa SQLite (arquivo local).
# Troque pelo URL do Postgres em produção.
#
# SQLite  (padrão para dev):
DATABASE_URL="file:./dev.db"
#
# PostgreSQL (produção):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sitetenis?schema=public"

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Segredo para assinar os tokens JWT (troque por um valor aleatório longo em prod)
JWT_SECRET="troque-este-segredo-em-producao"

# Tempo de expiração do token JWT (ex.: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas para o CORS (separadas por vírgula)
CORS_ORIGINS="http://localhost:5500,http://127.0.0.1:5500"
